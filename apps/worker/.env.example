# Worker secrets — set via `wrangler secret put <NAME>`
# Copy this to .dev.vars for local development

BOT_TOKEN=your_telegram_bot_token
BOT_WEBHOOK_SECRET=your_webhook_secret_random_string
JWT_SECRET=your_jwt_secret_min_32_chars
ENCRYPTION_KEY=your_aes_256_encryption_key_hex

# Optional: default AI provider for paid plans
DEFAULT_AI_API_BASE=https://api.openai.com/v1
DEFAULT_AI_API_KEY=sk-your-openai-key
DEFAULT_AI_MODEL=gpt-4o-mini

# Feature flags
FEATURE_TON_VERIFICATION=false
FEATURE_WALLETPAY=false
FEATURE_PDF_EXPORT=false

# TON verification (when FEATURE_TON_VERIFICATION=true)
TON_API_ENDPOINT=https://toncenter.com/api/v2
TON_API_KEY=

# Wallet Pay (when FEATURE_WALLETPAY=true)
WALLETPAY_API_KEY=
WALLETPAY_WEBHOOK_SECRET=
